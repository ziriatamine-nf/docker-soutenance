# ===========================================================================
#  Fichier d'exemple de variables d'environnement (VERSIONNÉ dans git).
#  ---------------------------------------------------------------------------
#  Pour démarrer le projet, copiez ce fichier en ".env" puis adaptez les valeurs :
#
#      cp .env.example .env        (Linux/macOS)
#      copy .env.example .env      (Windows CMD)
#      Copy-Item .env.example .env (Windows PowerShell)
#
#  Le vrai fichier ".env" contient des secrets : il est ignoré par git
#  (voir .gitignore). On ne versionne JAMAIS de mots de passe.
# ===========================================================================

# --- Identifiant Docker Hub --------------------------------------------------
# Sert à taguer les images (ex : votre-pseudo/todo-frontend:v1.0) en vue du push.
# Remplacez par votre pseudo Docker Hub.
DOCKERHUB_USER=votre-pseudo-dockerhub

# --- Identifiants MariaDB ----------------------------------------------------
# Utilisés par le conteneur "db" (création de la base + de l'utilisateur au
# premier démarrage) ET, par interpolation, par le backend pour se connecter.
MYSQL_ROOT_PASSWORD=changez_ce_mot_de_passe_root
MYSQL_DATABASE=todo_db
MYSQL_USER=todo_user
MYSQL_PASSWORD=changez_ce_mot_de_passe
